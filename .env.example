# Slack user OAuth token (xoxp-...) with users.profile:write scope
export SLACK_TOKEN=xoxp-your-token-here

# Spotify OAuth credentials — get these from https://developer.spotify.com/dashboard
export SPOTIFY_ID=your-client-id
export SPOTIFY_SECRET=your-client-secret

# Optional: override the redirect URI used during OAuth (default: http://127.0.0.1:8888/callback)
# export SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Optional: Spotify token as JSON string (for Render / ephemeral filesystems).
# Run `go run ./cmd/auth` locally, then copy the printed JSON here.
# If set, this takes priority over the spotify_token.json file.
# export SPOTIFY_TOKEN_JSON='{"access_token":"...","token_type":"Bearer","refresh_token":"...","expiry":"..."}'

# Optional: health server port (default: 8080, set automatically by Render)
# export PORT=8080
